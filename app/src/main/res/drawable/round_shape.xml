<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow Layer -->
    <item>
        <shape>
            <solid android:color="#80000000"/> <!-- Shadow Color -->
            <corners android:radius="60dp"/> <!-- Rounded Corner -->
        </shape>
    </item>

    <!-- Offset for Shadow -->
    <item android:top="5dp" android:left="5dp">
        <shape>
            <solid android:color="#FFFFFF"/> <!-- Main Background Color -->
            <corners android:radius="60dp"/>
        </shape>
    </item>
</layer-list>
