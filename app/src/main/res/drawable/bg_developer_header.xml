<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow layer -->
    <item
        android:left="0dp"
        android:top="2dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#33000000" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Main gradient layer -->
    <item
        android:bottom="2dp">
        <shape android:shape="rectangle">

            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#0D0D2B"
                android:centerColor="#1A1A6E"
                android:endColor="#4A3F9F" />


<!--            <corners-->
<!--                android:topLeftRadius="0dp"-->
<!--                android:topRightRadius="0dp"-->
<!--                android:bottomLeftRadius="0dp"-->
<!--                android:bottomRightRadius="0dp" />-->

            <!-- Subtle border for glass/premium feel -->
            <stroke
                android:width="1dp"
                android:color="#554A90FF" />

        </shape>
    </item>

    <!-- Top gloss/shine overlay -->
    <item
        android:bottom="50dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#22FFFFFF"
                android:endColor="#00FFFFFF" />
<!--            <corners-->
<!--                android:topLeftRadius="16dp"-->
<!--                android:topRightRadius="16dp"-->
<!--                android:bottomLeftRadius="0dp"-->
<!--                android:bottomRightRadius="0dp" />-->
        </shape>
    </item>

</layer-list>