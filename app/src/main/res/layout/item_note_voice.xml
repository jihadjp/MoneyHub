<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <!-- Top row: mic icon + label + play + delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_mic"
                android:alpha="0.7"
                app:tint="?attr/colorPrimary"
                android:contentDescription="Voice memo" />

            <TextView
                android:id="@+id/voiceLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Play / Pause -->
            <ImageButton
                android:id="@+id/voiceItemPlayBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_play"
                android:padding="6dp"
                android:contentDescription="Play"
                app:tint="?attr/colorPrimary" />

            <!-- Delete -->
            <ImageButton
                android:id="@+id/voiceItemDeleteBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_delete"
                android:padding="6dp"
                android:contentDescription="Delete"
                app:tint="?attr/colorError" />

        </LinearLayout>

        <!-- Seekbar row — only visible when playing -->
        <LinearLayout
            android:id="@+id/seekRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <!-- Elapsed time -->
            <TextView
                android:id="@+id/voiceCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:minWidth="32dp" />

            <!-- Seek bar -->
            <SeekBar
                android:id="@+id/voiceSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:progressTint="?attr/colorPrimary"
                android:thumbTint="?attr/colorPrimary" />

            <!-- Total duration -->
            <TextView
                android:id="@+id/voiceTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:minWidth="32dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>